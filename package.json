{
  "name": "@xgsd/runtime",
  "description": "lightweight orchestration library used by xGSD apps",
  "version": "0.0.3",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "repository": "https://github.com/Isolated-/xgsd-engine",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./process/block.process": {
      "require": "./dist/process/block.process.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "yarn clean && tsup",
    "clean": "rm -rf dist",
    "test": "yarn clean && jest ./src",
    "test:integration": "yarn clean && jest ./tests",
    "test:e2e": "yarn clean && jest ./e2e"
  },
  "devDependencies": {
    "@oclif/prettier-config": "^0.2.1",
    "@types/jest": "^30.0.0",
    "eventemitter2": "^6.4.9",
    "jest": "^29.x",
    "ts-jest": "^29.x",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.x"
  },
  "dependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/ms": "^2.1.0",
    "@xgsd/engine": "0.1.1",
    "fs-extra": "^11.3.4",
    "joi": "^18.1.2",
    "ms": "^2.1.3",
    "ts-deepmerge": "^7.0.3",
    "yaml": "^2.8.3"
  }
}
